{
  "name": "delete-deployment-environment",
  "version": "4.0.0",
  "type": "module",
  "main": "lib/main.js",
  "repository": "https://github.com/strumwolf/delete-deployment-environment.git",
  "author": "Brian Kurtz <lightsabre13@gmail.com>",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "ava --verbose",
    "lint": "eslint src/*.ts",
    "pack": "ncc build"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^9.0.0"
  },
  "devDependencies": {
    "@octokit/core": "^7.0.6",
    "@octokit/request-error": "^7.1.0",
    "@octokit/types": "^7.5.1",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vercel/ncc": "^0.38.0",
    "ava": "^4.3.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-escompat": "^3.11.4",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^4.3.8",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "yaml-lint": "^1.7.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --config .prettierrc --write"
    ],
    "*.*": [
      "prettier --config .prettierrc --write"
    ]
  },
  "ava": {
    "extensions": {
      "ts": "module"
    },
    "nodeArguments": [
      "--import=tsx/esm"
    ]
  }
}
